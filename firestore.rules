rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- Auth helpers ---------- */
    function signedIn() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function enabledDoc(path) {
      return exists(path) && get(path).data.enabled == true;
    }

    function isAllowed() {
      return signedIn()
        && myEmail() != null
        && enabledDoc(/databases/$(database)/documents/allowedEmails/$(myEmail()));
    }

    function isAdmin() {
      return isAllowed()
        && enabledDoc(/databases/$(database)/documents/admins/$(myEmail()));
    }

    function isServerTime(v) { return v == request.time; }
    function isTimestampOrServerTime(v) { return (v is timestamp) || isServerTime(v); }


    /* ---------- allowlist/admin docs ---------- */
    match /allowedEmails/{email} {
      allow read: if signedIn() && email == myEmail();
      allow write: if false;
    }

    match /admins/{email} {
      allow read: if signedIn() && email == myEmail();
      allow write: if false;
    }

    /* ---------- our history (read only) ---------- */
    match /ourHistoryEvents/{eventId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    /* ---------- app config / feature flags ---------- */
    match /appConfig/features {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    /* ---------- challenges ---------- */
    match /challenges/{challengeId} {

      function validTitle(v) {
        return v is string && v.size() > 0 && v.size() <= 60;
      }

      function validPrompt(v) {
        return v is string && v.size() > 0 && v.size() <= 200;
      }

      function hasValidPromptOrDescription(data) {
        return (("prompt" in data) && validPrompt(data.prompt))
          || (("description" in data) && validPrompt(data.description));
      }

      allow read: if isAdmin()
        || (
          isAllowed()
          && resource.data.isDeleted == false
          && resource.data.startAt != null
        );

      allow create: if isAdmin()
        || (
          isAllowed()
          && request.resource.data.createdByUid == request.auth.uid
          && validTitle(request.resource.data.title)
          && hasValidPromptOrDescription(request.resource.data)
          && isTimestampOrServerTime(request.resource.data.createdAt)
          && (request.resource.data.startAt == null || request.resource.data.startAt is timestamp)
          && (request.resource.data.endAt == null || request.resource.data.endAt is timestamp)
          && request.resource.data.isDeleted == false
          && request.resource.data.deletedAt == null
          && request.resource.data.deletedByUid == null
        );

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "title",
          "prompt",
          "description",
          "startAt",
          "endAt",
          "isDeleted",
          "deletedAt",
          "deletedByUid",
          "coverImageUrl",
          "createdByName"
        ])

        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(["endAt"])
            && isTimestampOrServerTime(request.resource.data.endAt)
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(["startAt", "endAt"])
            && resource.data.startAt == null
            && isTimestampOrServerTime(request.resource.data.startAt)
            && (request.resource.data.endAt == null || request.resource.data.endAt is timestamp)
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(["isDeleted","deletedAt","deletedByUid"])
            && request.resource.data.isDeleted == true
            && isTimestampOrServerTime(request.resource.data.deletedAt)
            && request.resource.data.deletedByUid is string
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "title", "prompt", "description", "coverImageUrl", "createdByName"
            ])
            && validTitle(request.resource.data.title)
            && hasValidPromptOrDescription(request.resource.data)
          )
        );

      allow delete: if false;
    }

    /* ---------- posts ---------- */
    match /posts/{postId} {

      allow read: if isAllowed();

      allow create: if isAllowed()
        && request.resource.data.userId == request.auth.uid
        && (!('commentsCount' in request.resource.data) || request.resource.data.commentsCount == 0)
        && (!('likesCount' in request.resource.data) || request.resource.data.likesCount == 0);

      allow update: if isAllowed()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId

        // Counters immutable
        && (!('commentsCount' in resource.data) || request.resource.data.commentsCount == resource.data.commentsCount)
        && (!('likesCount' in resource.data) || request.resource.data.likesCount == resource.data.likesCount)

        // 🔒 Bingo fields immutable once set
        && (
          !('bingoCardId' in resource.data)
          || request.resource.data.bingoCardId == resource.data.bingoCardId
        )
        && (
          !('bingoCellId' in resource.data)
          || request.resource.data.bingoCellId == resource.data.bingoCellId
        );

      allow delete: if isAllowed()
        && resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if isAllowed();
        allow create: if isAllowed() && request.auth.uid == userId;
        allow delete: if isAllowed() && request.auth.uid == userId;
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if isAllowed();

        allow create: if isAllowed()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;

        allow delete: if isAllowed()
          && resource.data.userId == request.auth.uid;

        allow update: if false;
      }
    }

    /* ---------- bingo winner ---------- */
    match /bingoWinners/{cardId} {
      allow read: if isAllowed();
      allow write: if false; // Only Cloud Functions
    }

    /* ---------- users ---------- */
    match /users/{uid} {
      allow read: if isAllowed();
      allow create, update: if isAllowed() && request.auth.uid == uid;
      allow delete: if false;
    }
  }
}
