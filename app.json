{
  "expo": {
    "name": "Henstagram",
    "slug": "henstagram-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "henstagrammobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "splash": {
      "image": "./assets/images/loading.jpg",
      "resizeMode": "cover"
    },
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.irene.tllo.henstagrammobile",
      "infoPlist": {
        "NSCameraUsageDescription": "We use the camera to let you take photos and videos for posts.",
        "NSPhotoLibraryUsageDescription": "We use your photo library so you can select media for posts.",
        "NSPhotoLibraryAddUsageDescription": "We save media to your library when you choose to export it.",
        "NSUserNotificationUsageDescription": "We send notifications when new challenges are activated so you don't miss them.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.irene_tllo.henstagrammobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e2527a7e-6c6f-4900-889e-fa584a4cfc58"
      }
    }
  }
}
